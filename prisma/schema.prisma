generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        Int           @id @default(autoincrement())
  email                     String        @unique
  name                      String?
  password                  String
  isEmailVerified           Boolean       @default(false)
  emailVerificationToken    String?       @unique
  emailVerificationExpires  DateTime?
  verificationAttempts      Int           @default(0)
  lastVerificationEmailSent DateTime?
  createdAt                 DateTime      @default(now())
  apiKeys                   ApiKey[]
  trackedSites              TrackedSite[]
}

model ApiKey {
  id        String    @id @default(uuid())
  key       String    @unique
  userId    Int       @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String?
  isActive  Boolean   @default(true)
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
}

model TrackedSite {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  url             String
  urlPattern      String?
  name            String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  errors          Error[]
  warnings        Warning[]
  infos           Info[]
  logs            Log[]
  performance     Performance[]
  userActions     UserAction[]
  networkRequests NetworkRequest[]
  securityEvents  SecurityEvent[]

  @@unique([userId, url])
}

model Error {
  id             Int         @id @default(autoincrement())
  siteId         Int
  site           TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  fingerprint    String
  type           String
  message        String
  stackTrace     String?
  fileName       String?
  lineNumber     Int?
  columnNumber   Int?
  url            String
  userAgent      String?
  count          Int         @default(1)
  firstSeenAt    DateTime    @default(now())
  lastSeenAt     DateTime    @default(now())
  lastInstanceId String?

  @@unique([siteId, fingerprint])
  @@index([siteId])
  @@index([lastInstanceId])
  @@index([lastSeenAt])
}

model Warning {
  id          Int         @id @default(autoincrement())
  siteId      Int
  site        TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  fingerprint String
  message     String
  stackTrace  String?
  url         String
  count       Int         @default(1)
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  @@unique([siteId, fingerprint])
  @@index([siteId])
  @@index([lastSeenAt])
}

model Info {
  id          Int         @id @default(autoincrement())
  siteId      Int
  site        TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  message     String
  url         String
  count       Int         @default(1)
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  @@index([siteId])
}

model Log {
  id          Int         @id @default(autoincrement())
  siteId      Int
  site        TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  message     String
  url         String
  count       Int         @default(1)
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  @@index([siteId])
}

model Performance {
  id         Int         @id @default(autoincrement())
  siteId     Int
  site       TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  metricType String
  metricName String
  value      Float
  rating     String?
  browser    String?
  url        String
  createdAt  DateTime    @default(now())

  @@index([siteId])
  @@index([metricName])
}

model UserAction {
  id         Int         @id @default(autoincrement())
  siteId     Int
  site       TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  actionType String
  details    Json?
  element    String?
  value      String?
  url        String
  createdAt  DateTime    @default(now())

  @@index([siteId])
  @@index([actionType])
}

model NetworkRequest {
  id          Int         @id @default(autoincrement())
  siteId      Int
  site        TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  method      String
  requestUrl  String
  pageUrl     String
  status      Int?
  duration    Int?
  failed      Boolean     @default(false)
  source      String
  browser     String?
  count       Int         @default(1)
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  @@unique([siteId, requestUrl, method, pageUrl, source])
  @@index([siteId])
  @@index([failed])
  @@index([duration])
}

model SecurityEvent {
  id          Int         @id @default(autoincrement())
  siteId      Int
  site        TrackedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type        String
  directive   String?
  blockedURI  String?
  url         String
  count       Int         @default(1)
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  @@index([siteId])
}
